@page "/"

@using shot_reminder_2.Contracts.Auth
@implements IDisposable
@inject shot_reminder_2.Client.Services.AuthService Auth

<PageTitle>Dashboard</PageTitle>

<MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Style="min-height: calc(100vh - 64px); text-align: center;">
    <MudText Typo="Typo.h4">Dashboard</MudText>

    @if (_loading)
    {
        <MudText>Loading...</MudText>
    }
    else if (!_isLoggedIn)
    {
        <MudText Class="mb-4">Welcome! Please log in to continue.</MudText>

        <MudPaper Class="pa-4" MaxWidth="400px">
            <MudTextField @bind-Value="_email" Label="Email" Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true" />
            <MudTextField @bind-Value="_password" Label="Password" Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true" InputType="InputType.Password" />

            <MudButton Disabled="@_submitting" Variant="Variant.Filled" Color="Color.Primary" OnClick="LoginAsync" Class="mt-3">
                Login
            </MudButton>

            @if (!string.IsNullOrWhiteSpace(_error))
            {
                <MudText Color="Color.Error" Class="mt-2">@_error</MudText>
            }
        </MudPaper>
    }
    else
    {
        <MudText Typo="Typo.h6" Class="mb-2">You're logged in.</MudText>
        <MudText>Dashboard content goes here.</MudText>
    }
</MudStack>

@code
    {
    private bool _loading = true;
    private bool _isLoggedIn;
    private bool _submitting;

    private string _email = string.Empty;
    private string _password = string.Empty;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        Auth.AuthStateChanged += OnAuthStateChanged;
        _isLoggedIn = await Auth.IsLoggedInAsync();
        _loading = false;
    }

    private void OnAuthStateChanged()
    {
        _ = InvokeAsync(async () =>
        {
            _isLoggedIn = await Auth.IsLoggedInAsync();
            StateHasChanged();
        });
    }

    public void Dispose()
        => Auth.AuthStateChanged -= OnAuthStateChanged;

    private async Task LoginAsync()
    {
        _error = null;
        _submitting = true;

        try
        {
            await Auth.LoginAsync(new LoginRequest(_email, _password));
            _isLoggedIn = true;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _submitting = false;
            _password = string.Empty;
        }
    }


}
